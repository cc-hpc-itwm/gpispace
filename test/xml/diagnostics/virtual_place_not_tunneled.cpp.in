#include <boost/test/unit_test.hpp>

#include <gspc/xml/parse/parser.hpp>
#include <gspc/xml/parse/state.hpp>
#include <gspc/xml/parse/warning.hpp>

#include <gspc/testing/flatten_nested_exceptions.hpp>
#include <gspc/testing/require_exception.hpp>

#include <fmt/core.h>
#include <gspc/util/fmt/std/filesystem/path.formatter.hpp>

BOOST_AUTO_TEST_CASE (virtual_place_not_tunneled)
{
  gspc::xml::parse::state::type state;

  state.warning_error() = true;
  state.warning_virtual_place_not_tunneled() = true;

  std::string const filename
    ("@XML_PARSE_TEST_XPNETS_DIR@/"
     "diagnostics/virtual_place_not_tunneled.xpnet"
    );

  gspc::testing::require_exception_with_message
    <gspc::xml::parse::warning::virtual_place_not_tunneled>
  ( [&state, &filename] { gspc::xml::parse::just_parse (state, filename); }
  , fmt::format ( "WARNING: the virtual place {} is not tunneled in {}."
                , "v"
                , std::filesystem::path {filename}
                )
  );
}
