#pragma once

#include <gspc/xml/parse/parser.hpp>
#include <gspc/xml/parse/state.hpp>

#include <gspc/we/type/Activity.hpp>
#include <gspc/we/type/net.hpp>

#include <gspc/util/read_file.hpp>

#include <gspc/testing/printer/generic.hpp>

#include <boost/test/unit_test.hpp>

#include <filesystem>
#include <optional>

GSPC_BOOST_TEST_LOG_VALUE_PRINTER (gspc::we::type::Activity, os, activity)
{
  os << activity.to_string();
}

namespace
{
  struct parser_fixture
  {
    parser_fixture()
      : state()
      , function (std::nullopt)
    {
      path_to_xpnets = "@XML_PARSE_TEST_XPNETS_DIR@";
    }

    void parse (std::filesystem::path const& path)
    {
      set_parse_input (path);
      parse();
    }

    void set_parse_input (std::filesystem::path const& path)
    {
      xpnet = path_to_xpnets / path;
    }
    void parse()
    {
      function = ::gspc::xml::parse::just_parse (state, xpnet.string());
    }

    ::gspc::xml::parse::state::type state;
    std::optional< ::gspc::xml::parse::type::function_type> function;

    std::filesystem::path xpnet;
    std::filesystem::path path_to_xpnets;
  };
}
