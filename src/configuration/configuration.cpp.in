#include <gspc/configuration/info.hpp>
#include <gspc/configuration/version.hpp>

#include <sstream>

namespace gspc::configuration
{
  const char* version()
  {
    return "@PROJECT_VERSION@";
  }

  std::string info (std::string const& head)
  {
    std::ostringstream s;

    s << "GPI-Space - productive parallel programming and efficient execution"
      << std::endl
      << std::endl << "  * " << head << std::endl
      << std::endl << "version:  " << version()
      << std::endl << "contact:  @PROJECT_CONTACT@"
      << std::endl
      << std::endl << "Copyright 2009-@COPYRIGHT_YEAR@ Fraunhofer ITWM"
      << std::endl
      ;

    return s.str();
  }
}
