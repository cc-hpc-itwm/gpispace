#pragma once

#include <gspc/util/executable_path.hpp>

#include <filesystem>

namespace gspc
{
  class installation_path
  {
  public:
    installation_path()
      : _path (gspc::util::executable_path().parent_path().parent_path())
    {}
    installation_path (std::filesystem::path const& gspc_home)
      : _path (gspc_home)
    {}

    operator std::filesystem::path const&() const
    {
      return _path;
    }

    std::filesystem::path include() const
    {
      return _path / "include";
    }
    std::filesystem::path lib() const
    {
      return _path / "@CMAKE_INSTALL_LIBDIR@";
    }
    std::filesystem::path boost_root() const
    {
      return _path / "external" / "boost";
    }
    std::filesystem::path libexec_gspc() const
    {
      return _path / "libexec" / "gspc";
    }
    std::filesystem::path agent() const
    {
      return libexec_gspc() / "gspc-agent";
    }
    std::filesystem::path drts_kernel() const
    {
      return libexec_gspc() / "gspc-drts-kernel";
    }
    std::filesystem::path logging_demultiplexer() const
    {
      return libexec_gspc() / "gspc-logging-demultiplexer.exe";
    }

  private:
    std::filesystem::path _path;
  };
}
