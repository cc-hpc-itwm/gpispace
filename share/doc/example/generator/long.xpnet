<!-- Example network demonstrating generator places with long type.
     The generator place produces unique long values: 0L, 1L, 2L, ...
     This workflow consumes n tokens from the generator and outputs
     them as individual tokens. -->

<defun name="generator_long">

  <in name="n" type="unsigned long" place="count"/>
  <out name="id" type="long" place="id"/>

  <net>

    <place name="count" type="unsigned long"/>
    <place name="generator" type="long" generator="true"/>
    <place name="id" type="long"/>

    <transition name="consume">
      <defun>
        <inout name="count" type="unsigned long"/>
        <inout name="id" type="long"/>
        <expression>
          ${count} := ${count} - 1UL;
        </expression>
      </defun>
      <condition>
        ${count} :gt: 0UL
      </condition>
      <connect-inout port="count" place="count"/>
      <connect-in port="id" place="generator"/>
      <connect-out port="id" place="id"/>
    </transition>

    <transition name="done">
      <defun>
        <in name="count" type="unsigned long"/>
        <expression/>
      </defun>
      <condition>
        ${count} :le: 0UL
      </condition>
      <connect-in port="count" place="count"/>
    </transition>

  </net>

</defun>
