<!-- Example network demonstrating generator places with string type.
     The generator place produces unique string values: "a", "b", ..., "z",
     "aa", "ab", ..., "az", "ba", ..., "zz", "aaa", ...
     This workflow consumes n tokens from the generator and outputs
     them as individual tokens. -->

<defun name="generator_string">

  <in name="n" type="unsigned long" place="count"/>
  <out name="id" type="string" place="out"/>

  <net>

    <place name="count" type="unsigned long"/>
    <place name="generator" type="string" generator="true"/>
    <place name="out" type="string"/>

    <transition name="consume">
      <defun>
        <inout name="count" type="unsigned long"/>
        <in name="id" type="string"/>
        <out name="out" type="string"/>
        <expression>
          ${out} := ${id};
          ${count} := ${count} - 1UL;
        </expression>
      </defun>
      <condition>
        ${count} :gt: 0UL
      </condition>
      <connect-inout port="count" place="count"/>
      <connect-in port="id" place="generator"/>
      <connect-out port="out" place="out"/>
    </transition>

    <transition name="done">
      <defun>
        <in name="count" type="unsigned long"/>
        <expression/>
      </defun>
      <condition>
        ${count} :le: 0UL
      </condition>
      <connect-in port="count" place="count"/>
    </transition>

  </net>

</defun>
